# FixMyUI Agent — environment variables
# Copy this file to .env and fill in your values.
# These override any values in .fixmyui.json

# URL of the FixMyUI SaaS (no trailing slash)
FIXMYUI_API_URL=https://fixmyui.com

# Your installation's agent secret (shown once in the dashboard)
FIXMYUI_AGENT_SECRET=fmui_sk_xxx

# Installation ID (numeric, found in the dashboard URL: /fixmyui/installations/{id})
# Set automatically by `fixmyui init`, or override here
FIXMYUI_INSTALLATION_ID=

# Prefix for git branches created per job  (default: fixmyui)
FIXMYUI_BRANCH_PREFIX=fixmyui

# Push branches automatically after Claude commits  (default: true)
FIXMYUI_AUTO_PUSH=true

# Optional: template for the preview URL shown in the widget
# Use {branch} as a placeholder, e.g.:
# FIXMYUI_PREVIEW_URL_TEMPLATE=https://staging.myapp.com?branch={branch}
FIXMYUI_PREVIEW_URL_TEMPLATE=

# Optional overrides for WebSocket (normally loaded from GET /api/fixmyui/agent/me)
# FIXMYUI_REVERB_APP_KEY=
# FIXMYUI_REVERB_HOST=localhost
# FIXMYUI_REVERB_PORT=8080
# FIXMYUI_REVERB_SCHEME=http
